{
  "name": "proximityvc-bridge",
  "version": "1.0.0",
  "description": "Discord IPC bridge for ProximityVC Minecraft mod",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --output proximityvc-bridge"
  },
  "pkg": {
    "scripts": ["discordRpc.js"],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ]
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.20.7"
  }
}
